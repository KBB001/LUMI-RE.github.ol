# ═════════════════════════════════════════════════════════════
# LUMIÈRE Environment Variables
# Copy this to .env and fill in with your own values
# NEVER commit .env to version control!
# ═════════════════════════════════════════════════════════════

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=https://kbb001.github.io

# JWT Configuration
# ⚠️ IMPORTANT: In production, generate a strong random secret!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Database Configuration (if using SQLite/MongoDB)
DATABASE_URL=
DB_NAME=lumiere

# Email Configuration (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lumiere.kz

# API Keys (third-party services)
KASPI_API_KEY=
HALYK_API_KEY=

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_change_this

# Logging
LOG_LEVEL=info

# Third-party integrations
SENTRY_DSN=
